<div class="min-h-screen flex items-center justify-center px-4"
     style="background: radial-gradient(1200px 600px at 50% -100px, rgba(79,110,247,0.15), transparent), #0a0e1a;">
  <div class="w-full max-w-sm">
    <div class="flex flex-col items-center mb-8">
      <div class="w-14 h-14 rounded-2xl bg-accent/20 border border-accent/40 flex items-center justify-center mb-4">
        <i data-lucide="shield" class="text-accent" style="width:28px;height:28px;"></i>
      </div>
      <h1 class="text-xl font-semibold text-white tracking-wide">FORTRIX</h1>
      <p class="text-xs uppercase tracking-widest text-slate-500 mt-1">Endpoint Protection Console</p>
    </div>

    <div class="bg-panel border border-line rounded-2xl p-6 shadow-2xl shadow-black/40">
      <% if (error) { %>
        <div class="mb-4 px-3 py-2.5 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm flex items-center gap-2">
          <i data-lucide="alert-triangle" style="width:16px;height:16px;"></i>
          <span><%= error %></span>
        </div>
      <% } %>
      <form method="post" action="/app/login" class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-slate-400 mb-1.5">Username</label>
          <input name="username" type="text" required autofocus autocomplete="username"
                 class="w-full px-3 py-2.5 rounded-xl bg-ink border border-line text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-accent/60 focus:ring-1 focus:ring-accent/40"
                 placeholder="admin" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-400 mb-1.5">Password</label>
          <input name="password" type="password" required autocomplete="current-password"
                 class="w-full px-3 py-2.5 rounded-xl bg-ink border border-line text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-accent/60 focus:ring-1 focus:ring-accent/40"
                 placeholder="••••••••••••••••" />
        </div>
        <button type="submit"
                class="w-full py-2.5 rounded-xl bg-accent hover:bg-accent/90 text-white text-sm font-semibold transition shadow-lg shadow-accent/25">
          Sign in
        </button>
      </form>
    </div>

    <p class="text-center text-xs text-slate-600 mt-6">Fortrix — data exfiltration detection &amp; behavioral monitoring</p>
  </div>
</div>
