<div class="flex items-center justify-between mb-4">
  <h2 class="text-sm font-semibold text-white">Auto-Protect Rules</h2>
  <span class="text-xs text-slate-500"><%= rules.length %> rule<%= rules.length === 1 ? '' : 's' %></span>
</div>

<p class="text-xs text-slate-500 mb-4">Rules that automatically trigger protective actions (isolate, kill process, block IP) when an alert matches specific conditions.</p>

<!-- Add Form -->
<div class="bg-panel2 border border-line rounded-2xl p-4 mb-5">
  <h3 class="text-xs font-semibold text-white mb-3">Add Rule</h3>
  <form method="post" action="/app/protect" class="grid grid-cols-1 md:grid-cols-4 gap-3">
    <input name="name" placeholder="Rule name" required maxlength="128"
           class="px-3 py-2 rounded-xl bg-ink border border-line text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-accent/60" />
    <select name="event_type" required
            class="px-3 py-2 rounded-xl bg-ink border border-line text-sm text-slate-200 focus:outline-none focus:border-accent/60">
      <option value="">Event type</option>
      <option value="fs.read_burst">File Read Burst</option>
      <option value="net.outbound_new_remote">Outbound Network</option>
      <option value="proc.new">New Process</option>
      <option value="clipboard.rapid_changes">Clipboard Flood</option>
    </select>
    <select name="action_type" required
            class="px-3 py-2 rounded-xl bg-ink border border-line text-sm text-slate-200 focus:outline-none focus:border-accent/60">
      <option value="">Action</option>
      <option value="alert_only">Alert Only</option>
      <option value="isolate">Isolate Network</option>
      <option value="kill_process">Kill Process</option>
      <option value="block_ip">Block IP</option>
    </select>
    <input name="condition_json" placeholder='{"severity":"critical"}' maxlength="2000"
           class="px-3 py-2 rounded-xl bg-ink border border-line text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-accent/60 font-mono text-xs" />
    <div class="md:col-span-4 flex items-center gap-3">
      <label class="flex items-center gap-2 text-xs text-slate-400">
        <input type="checkbox" name="enabled" value="1" checked class="rounded bg-ink border-line" /> Enabled
      </label>
      <button type="submit" class="px-4 py-2 rounded-xl bg-accent hover:bg-accent/90 text-white text-xs font-semibold transition">Add Rule</button>
    </div>
  </form>
</div>

<!-- Rules List -->
<% if (rules.length === 0) { %>
  <div class="text-sm text-slate-500 py-10 text-center">No protect rules defined yet.</div>
<% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs uppercase tracking-wider text-slate-500 border-b border-line">
          <th class="py-2.5 pr-4 font-medium">Name</th>
          <th class="py-2.5 pr-4 font-medium">Event</th>
          <th class="py-2.5 pr-4 font-medium">Condition</th>
          <th class="py-2.5 pr-4 font-medium">Action</th>
          <th class="py-2.5 pr-4 font-medium">Status</th>
          <th class="py-2.5 font-medium"></th>
        </tr>
      </thead>
      <tbody>
        <% for (const r of rules) { %>
          <tr class="border-b border-line/50 hover:bg-panel2/60">
            <td class="py-2.5 pr-4 text-slate-300"><%= r.name %></td>
            <td class="py-2.5 pr-4 font-mono text-xs text-slate-400"><%= r.event_type %></td>
            <td class="py-2.5 pr-4 font-mono text-xs text-slate-500 max-w-[200px] truncate"><%= r.condition_json %></td>
            <td class="py-2.5 pr-4">
              <span class="px-2 py-0.5 rounded-lg text-[10px] font-medium <%= r.action_type === 'alert_only' ? 'bg-sky-500/15 text-sky-300 border border-sky-500/30' : 'bg-red-500/15 text-red-400 border border-red-500/30' %>"><%= r.action_type %></span>
            </td>
            <td class="py-2.5 pr-4">
              <button onclick="toggleRule(<%= r.id %>)" class="<%= r.enabled ? 'text-emerald-400' : 'text-slate-600' %> text-xs hover:underline"><%= r.enabled ? 'ON' : 'OFF' %></button>
            </td>
            <td class="py-2.5">
              <% if (roleRank >= 3) { %>
                <button onclick="deleteRule(<%= r.id %>)" class="text-red-400 text-xs hover:underline">Delete</button>
              <% } %>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } %>

<script>
function toggleRule(id) {
  fetch("/app/protect/" + id + "/toggle", { method: "POST" }).then(function() { location.reload(); });
}
function deleteRule(id) {
  if (confirm("Delete this rule?")) {
    fetch("/app/protect/" + id + "/delete", { method: "POST" }).then(function() { location.reload(); });
  }
}
</script>
