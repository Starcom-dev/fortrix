<!-- Create org -->
<div class="bg-panel border border-line rounded-2xl p-5">
  <h2 class="text-sm font-semibold text-white mb-1">Add organization</h2>
  <p class="text-xs text-slate-500 mb-4">Creates the org with a default enroll key. Optionally create the initial owner account (password shown once).</p>
  <form method="post" action="/app/orgs" class="flex flex-wrap items-end gap-3">
    <div>
      <label class="block text-xs text-slate-500 mb-1">Organization name</label>
      <input type="text" name="name" required maxlength="128" placeholder="e.g. PT Maju Sejahtera"
             class="w-64 bg-ink border border-line rounded-xl px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-accent/60" />
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Owner username (optional)</label>
      <input type="text" name="owner_username" minlength="3" maxlength="64" placeholder="e.g. maju.admin"
             class="w-52 bg-ink border border-line rounded-xl px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-accent/60" />
    </div>
    <button type="submit" class="px-4 py-2 rounded-xl bg-accent hover:bg-accent/90 text-white text-sm font-medium transition flex items-center gap-2">
      <i data-lucide="building-2" style="width:14px;height:14px;"></i> Create organization
    </button>
  </form>
</div>

<!-- Org list -->
<div class="bg-panel border border-line rounded-2xl p-5">
  <h2 class="text-sm font-semibold text-white mb-4">Organizations</h2>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-xs uppercase tracking-wider text-slate-500 border-b border-line">
          <th class="py-2.5 pr-4 font-medium">ID</th>
          <th class="py-2.5 pr-4 font-medium">Name</th>
          <th class="py-2.5 pr-4 font-medium">Devices</th>
          <th class="py-2.5 pr-4 font-medium">Users</th>
          <th class="py-2.5 pr-4 font-medium">Open alerts</th>
          <th class="py-2.5 pr-4 font-medium">Created</th>
          <th class="py-2.5 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (const o of orgs) { %>
          <tr class="border-b border-line/50 hover:bg-panel2/60">
            <td class="py-2.5 pr-4 text-slate-500">#<%= o.id %></td>
            <td class="py-2.5 pr-4 text-slate-200 font-medium"><%= o.name %></td>
            <td class="py-2.5 pr-4 text-slate-300"><%= o.device_count %></td>
            <td class="py-2.5 pr-4 text-slate-300"><%= o.user_count %></td>
            <td class="py-2.5 pr-4">
              <% if (o.open_alerts > 0) { %>
                <span class="px-2 py-0.5 rounded-lg text-[10px] font-medium bg-red-500/15 text-red-400 border border-red-500/30"><%= o.open_alerts %></span>
              <% } else { %>
                <span class="text-slate-500">0</span>
              <% } %>
            </td>
            <td class="py-2.5 pr-4 text-slate-500 text-xs whitespace-nowrap" data-ts="<%= o.created_at %>"><%= o.created_at %></td>
            <td class="py-2.5">
              <div class="flex items-center gap-1.5">
                <form method="post" action="/app/org/switch" class="inline">
                  <input type="hidden" name="org_id" value="<%= o.id %>" />
                  <button type="submit" class="px-2.5 py-1 rounded-lg text-[11px] font-medium bg-accent/10 text-accent border border-accent/30 hover:bg-accent/20 transition">View</button>
                </form>
                <form method="post" action="/app/orgs/<%= o.id %>/rename" class="inline-flex items-center gap-1.5">
                  <input type="text" name="name" placeholder="New name" maxlength="128" required
                         class="w-36 bg-ink border border-line rounded-lg px-2 py-1 text-[11px] text-slate-200 placeholder-slate-600 focus:outline-none focus:border-accent/60" />
                  <button type="submit" class="px-2.5 py-1 rounded-lg text-[11px] font-medium bg-panel2 border border-line text-slate-300 hover:bg-line transition">Rename</button>
                </form>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
