<div class="bg-panel border border-line rounded-2xl p-5">
  <h2 class="text-sm font-semibold text-white mb-1">Audit log</h2>
  <p class="text-xs text-slate-500 mb-4">Last 200 administrative actions in this organization.</p>
  <% if (entries.length === 0) { %>
    <div class="text-sm text-slate-500 py-8 text-center">No audit entries yet.</div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs uppercase tracking-wider text-slate-500 border-b border-line">
            <th class="py-2.5 pr-4 font-medium">Time</th>
            <th class="py-2.5 pr-4 font-medium">User</th>
            <th class="py-2.5 pr-4 font-medium">Action</th>
            <th class="py-2.5 pr-4 font-medium">Details</th>
            <th class="py-2.5 font-medium">IP</th>
          </tr>
        </thead>
        <tbody>
          <% for (const e of entries) { %>
            <tr class="border-b border-line/50 hover:bg-panel2/60">
              <td class="py-2.5 pr-4 text-slate-500 text-xs whitespace-nowrap" data-ts="<%= e.created_at %>"><%= e.created_at %></td>
              <td class="py-2.5 pr-4 text-slate-300"><%= e.username || 'system' %></td>
              <td class="py-2.5 pr-4">
                <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-ink text-accent"><%= e.action %></code>
              </td>
              <td class="py-2.5 pr-4 text-slate-400 text-xs break-all"><%= e.details %></td>
              <td class="py-2.5 text-slate-500 text-xs font-mono"><%= e.ip %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
