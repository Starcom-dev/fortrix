<!-- Fleet cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
  <div class="bg-panel border border-line rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs uppercase tracking-widest text-slate-500">Devices Online</span>
      <i data-lucide="monitor" class="text-accent" style="width:18px;height:18px;"></i>
    </div>
    <div class="text-3xl font-semibold text-white"><%= fleet.online %><span class="text-slate-500 text-xl font-normal"> / <%= fleet.total %></span></div>
    <div class="text-xs text-slate-500 mt-1">fleet total</div>
  </div>

  <div class="bg-panel border border-line rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs uppercase tracking-widest text-slate-500">Open Alerts</span>
      <i data-lucide="siren" class="text-red-400" style="width:18px;height:18px;"></i>
    </div>
    <div class="text-3xl font-semibold text-white"><%= openTotal %></div>
    <div class="flex flex-wrap gap-1.5 mt-2">
      <% for (const sev of ['critical','high','medium','low','info']) { if (openBySeverity[sev] > 0) { %>
        <span class="px-2 py-0.5 rounded-lg text-[10px] font-medium <%= sevBadge(sev) %>"><%= sev %> <%= openBySeverity[sev] %></span>
      <% } } %>
      <% if (openTotal === 0) { %><span class="text-xs text-slate-500">all clear</span><% } %>
    </div>
  </div>

  <div class="bg-panel border border-line rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs uppercase tracking-widest text-slate-500">Events (24h)</span>
      <i data-lucide="activity" class="text-emerald-400" style="width:18px;height:18px;"></i>
    </div>
    <div class="text-3xl font-semibold text-white"><%= events24h %></div>
    <div class="text-xs text-slate-500 mt-1">ingested last 24 hours</div>
  </div>

  <div class="bg-panel border border-line rounded-2xl p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs uppercase tracking-widest text-slate-500">Critical / High</span>
      <i data-lucide="shield-alert" class="text-orange-400" style="width:18px;height:18px;"></i>
    </div>
    <div class="text-3xl font-semibold text-white"><%= openBySeverity.critical + openBySeverity.high %></div>
    <div class="text-xs text-slate-500 mt-1">open, needs attention</div>
  </div>
</div>

<!-- Alerts timeline -->
<div class="bg-panel border border-line rounded-2xl p-5">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-white">Alerts timeline — last 24h</h2>
    <span class="text-xs text-slate-500">UTC, hourly</span>
  </div>
  <div class="h-64"><canvas id="alertsChart"></canvas></div>
</div>

<!-- Recent alerts -->
<div class="bg-panel border border-line rounded-2xl p-5">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-white">Recent alerts</h2>
    <a href="/app/alerts" class="text-xs text-accent hover:underline">View all →</a>
  </div>
  <% if (recentAlerts.length === 0) { %>
    <div class="text-sm text-slate-500 py-8 text-center">No alerts yet. Fleet is quiet.</div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs uppercase tracking-wider text-slate-500 border-b border-line">
            <th class="py-2.5 pr-4 font-medium">Severity</th>
            <th class="py-2.5 pr-4 font-medium">Title</th>
            <th class="py-2.5 pr-4 font-medium">Device</th>
            <th class="py-2.5 pr-4 font-medium">Rule</th>
            <th class="py-2.5 pr-4 font-medium">Status</th>
            <th class="py-2.5 font-medium">Time</th>
          </tr>
        </thead>
        <tbody>
          <% for (const a of recentAlerts) { %>
            <tr class="border-b border-line/50 hover:bg-panel2/60">
              <td class="py-2.5 pr-4"><span class="px-2 py-0.5 rounded-lg text-[10px] font-medium <%= sevBadge(a.severity) %>"><%= a.severity %></span></td>
              <td class="py-2.5 pr-4 text-slate-200"><%= a.title %></td>
              <td class="py-2.5 pr-4"><a class="text-accent hover:underline" href="/app/devices/<%= a.device_id %>"><%= a.hostname %></a></td>
              <td class="py-2.5 pr-4 text-slate-400 font-mono text-xs"><%= a.rule %></td>
              <td class="py-2.5 pr-4"><span class="px-2 py-0.5 rounded-lg text-[10px] font-medium <%= statusBadge(a.status) %>"><%= a.status %></span></td>
              <td class="py-2.5 text-slate-500 text-xs" data-ts="<%= a.created_at %>"><%= a.created_at %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>
  (function () {
    var chart = <%- JSON.stringify(chart) %>;
    var colors = {
      critical: '#ef4444',
      high: '#f97316',
      medium: '#f59e0b',
      low: '#38bdf8',
      info: '#64748b',
    };
    var datasets = Object.keys(chart.datasets).map(function (sev) {
      return {
        label: sev,
        data: chart.datasets[sev],
        backgroundColor: colors[sev],
        borderRadius: 4,
        stack: 'alerts',
      };
    });
    new Chart(document.getElementById('alertsChart'), {
      type: 'bar',
      data: { labels: chart.labels, datasets: datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { labels: { color: '#94a3b8', boxWidth: 10, font: { size: 11 } } },
        },
        scales: {
          x: { stacked: true, grid: { color: 'rgba(30,39,66,0.5)' }, ticks: { color: '#64748b', font: { size: 10 } } },
          y: { stacked: true, beginAtZero: true, grid: { color: 'rgba(30,39,66,0.5)' }, ticks: { color: '#64748b', precision: 0 } },
        },
      },
    });
  })();
</script>
