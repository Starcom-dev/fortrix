<div class="flex items-center gap-2 text-xs text-slate-500">
  <a href="/app/devices" class="text-accent hover:underline">Devices</a>
  <span>/</span>
  <span class="text-slate-300"><%= device.hostname %></span>
</div>

<!-- Device info -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="bg-panel border border-line rounded-2xl p-5 lg:col-span-2">
    <div class="flex items-start justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-accent/15 border border-accent/30 flex items-center justify-center">
          <i data-lucide="monitor" class="text-accent" style="width:20px;height:20px;"></i>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-white"><%= device.hostname %></h2>
          <div class="text-xs text-slate-500"><%= device.os %> · <%= device.arch %> · agent <%= device.agent_version || '?' %></div>
        </div>
      </div>
      <span class="px-2.5 py-1 rounded-lg text-xs font-medium <%= statusBadge(device.status) %>"><%= device.status %></span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-5 text-sm">
      <div>
        <div class="text-xs text-slate-500 mb-0.5">IP</div>
        <div class="font-mono text-xs text-slate-300"><%= device.ip || '—' %></div>
      </div>
      <div>
        <div class="text-xs text-slate-500 mb-0.5">Enrolled</div>
        <div class="text-xs text-slate-300" data-ts="<%= device.enrolled_at %>"><%= device.enrolled_at %></div>
      </div>
      <div>
        <div class="text-xs text-slate-500 mb-0.5">Last seen</div>
        <div class="text-xs text-slate-300" data-ts="<%= device.last_seen %>"><%= device.last_seen %></div>
      </div>
      <div>
        <div class="text-xs text-slate-500 mb-0.5">Open alerts</div>
        <div class="text-xs <%= openAlertCount > 0 ? 'text-red-400 font-semibold' : 'text-slate-300' %>"><%= openAlertCount %></div>
      </div>
    </div>
  </div>

  <div class="bg-panel border border-line rounded-2xl p-5">
    <h3 class="text-sm font-semibold text-white mb-3">Latest heartbeat</h3>
    <% if (lastHb) { %>
      <div class="space-y-3 text-sm">
        <div>
          <div class="flex justify-between text-xs mb-1"><span class="text-slate-500">CPU</span><span class="text-slate-300"><%= lastHb.cpu_pct != null ? lastHb.cpu_pct.toFixed(1) + '%' : '—' %></span></div>
          <div class="h-1.5 bg-ink rounded-full overflow-hidden"><div class="h-full bg-accent rounded-full" style="width: <%= Math.min(100, lastHb.cpu_pct || 0) %>%"></div></div>
        </div>
        <div>
          <div class="flex justify-between text-xs mb-1"><span class="text-slate-500">Memory</span><span class="text-slate-300"><%= lastHb.mem_pct != null ? lastHb.mem_pct.toFixed(1) + '%' : '—' %></span></div>
          <div class="h-1.5 bg-ink rounded-full overflow-hidden"><div class="h-full bg-emerald-400 rounded-full" style="width: <%= Math.min(100, lastHb.mem_pct || 0) %>%"></div></div>
        </div>
        <div class="flex justify-between text-xs pt-1">
          <span class="text-slate-500">Uptime</span>
          <span class="text-slate-300"><%= lastHb.uptime_s != null ? Math.floor(lastHb.uptime_s / 3600) + 'h ' + Math.floor((lastHb.uptime_s % 3600) / 60) + 'm' : '—' %></span>
        </div>
      </div>
    <% } else { %>
      <div class="text-xs text-slate-500 py-4 text-center">No heartbeats received yet.</div>
    <% } %>
  </div>
</div>

<!-- Heartbeat metrics chart -->
<div class="bg-panel border border-line rounded-2xl p-5">
  <h3 class="text-sm font-semibold text-white mb-4">Heartbeat metrics — CPU / Memory</h3>
  <% if (hbChart.labels.length === 0) { %>
    <div class="text-sm text-slate-500 py-8 text-center">No metric history yet.</div>
  <% } else { %>
    <div class="h-56"><canvas id="hbChart"></canvas></div>
  <% } %>
</div>

<!-- Recent events -->
<div class="bg-panel border border-line rounded-2xl p-5">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-sm font-semibold text-white">Recent events</h3>
    <a href="/app/events?device_id=<%= device.id %>" class="text-xs text-accent hover:underline">Explore →</a>
  </div>
  <% if (recentEvents.length === 0) { %>
    <div class="text-sm text-slate-500 py-8 text-center">No events from this device yet.</div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs uppercase tracking-wider text-slate-500 border-b border-line">
            <th class="py-2.5 pr-4 font-medium">Type</th>
            <th class="py-2.5 pr-4 font-medium">Severity</th>
            <th class="py-2.5 pr-4 font-medium">Data</th>
            <th class="py-2.5 font-medium">Time</th>
          </tr>
        </thead>
        <tbody>
          <% for (const e of recentEvents) { %>
            <tr class="border-b border-line/50 hover:bg-panel2/60 align-top">
              <td class="py-2.5 pr-4 font-mono text-xs text-slate-200"><%= e.type %></td>
              <td class="py-2.5 pr-4"><span class="px-2 py-0.5 rounded-lg text-[10px] font-medium <%= sevBadge(e.severity) %>"><%= e.severity %></span></td>
              <td class="py-2.5 pr-4"><code class="text-[11px] text-slate-400 break-all"><%= e.data.length > 160 ? e.data.slice(0, 160) + '…' : e.data %></code></td>
              <td class="py-2.5 text-slate-500 text-xs whitespace-nowrap" data-ts="<%= e.created_at %>"><%= e.created_at %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<% if (hbChart.labels.length > 0) { %>
<script>
  (function () {
    var hb = <%- JSON.stringify(hbChart) %>;
    new Chart(document.getElementById('hbChart'), {
      type: 'line',
      data: {
        labels: hb.labels,
        datasets: [
          { label: 'CPU %', data: hb.cpu, borderColor: '#4f6ef7', backgroundColor: 'rgba(79,110,247,0.12)', fill: true, tension: 0.35, pointRadius: 0 },
          { label: 'Mem %', data: hb.mem, borderColor: '#34d399', backgroundColor: 'rgba(52,211,153,0.08)', fill: true, tension: 0.35, pointRadius: 0 },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { labels: { color: '#94a3b8', boxWidth: 10, font: { size: 11 } } } },
        scales: {
          x: { grid: { color: 'rgba(30,39,66,0.5)' }, ticks: { color: '#64748b', font: { size: 10 } } },
          y: { beginAtZero: true, max: 100, grid: { color: 'rgba(30,39,66,0.5)' }, ticks: { color: '#64748b' } },
        },
      },
    });
  })();
</script>
<% } %>
