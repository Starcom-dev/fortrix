<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' && title ? title + ' — Fortrix' : 'Fortrix' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            ink: '#0a0e1a',
            panel: '#10162a',
            panel2: '#141c33',
            line: '#1e2742',
            accent: '#4f6ef7',
          },
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui', 'Segoe UI', 'sans-serif'],
          },
        },
      },
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <style>
    body { background: #0a0e1a; }
    ::-webkit-scrollbar { width: 10px; height: 10px; }
    ::-webkit-scrollbar-track { background: #0a0e1a; }
    ::-webkit-scrollbar-thumb { background: #1e2742; border-radius: 8px; }
    ::-webkit-scrollbar-thumb:hover { background: #2a3554; }
  </style>
</head>
<body class="bg-ink text-slate-200 min-h-screen font-sans antialiased">
<% if (typeof bare !== 'undefined' && bare) { %>
  <%- body %>
<% } else { %>
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="hidden md:flex w-60 shrink-0 flex-col border-r border-line bg-panel/60 backdrop-blur">
      <div class="flex items-center gap-2.5 px-5 h-16 border-b border-line">
        <div class="w-8 h-8 rounded-xl bg-accent/20 border border-accent/40 flex items-center justify-center">
          <i data-lucide="shield" class="w-4.5 h-4.5 text-accent" style="width:18px;height:18px;"></i>
        </div>
        <div>
          <div class="text-sm font-semibold tracking-wide text-white">FORTRIX</div>
          <div class="text-[10px] uppercase tracking-widest text-slate-500"><%= typeof isCustomerHost !== "undefined" && isCustomerHost ? "Device Monitor" : "Endpoint Protection" %></div>
        </div>
      </div>
      <nav class="flex-1 px-3 py-4 space-y-1">
        <% 
          const rank = typeof roleRank !== 'undefined' ? roleRank : 0;
          const superUser = typeof isSuper !== 'undefined' && isSuper;
          const isCustomer = typeof isCustomerHost !== 'undefined' && isCustomerHost;
          const nav = [
            { href: '/app', icon: 'layout-dashboard', label: 'Overview', key: 'overview' },
            { href: '/app/devices', icon: 'monitor', label: 'Devices', key: 'devices' },
            { href: '/app/alerts', icon: 'siren', label: 'Alerts', key: 'alerts' },
            { href: '/app/events', icon: 'list', label: 'Events', key: 'events' },
          ];
          if (rank >= 3) nav.push({ href: '/app/users', icon: 'users', label: 'Users', key: 'users' });
          if (rank >= 3) nav.push({ href: '/app/audit', icon: 'scroll-text', label: 'Audit Log', key: 'audit' });
          if (rank >= 2) { nav.push({ href: '/app/settings', icon: 'settings', label: 'Settings', key: 'settings' }); nav.push({ href: '/app/agent/versions', icon: 'package-open', label: 'Agent Versions', key: 'agent_versions' }); }
          if (rank >= 2 && !isCustomer) { nav.push({ href: '/app/protect', icon: 'shield-alert', label: 'Protect Rules', key: 'protect' }); nav.push({ href: '/app/app-control', icon: 'scan-search', label: 'App Control', key: 'app_control' }); }
          if (superUser && !isCustomer) nav.push({ href: '/app/orgs', icon: 'building-2', label: 'Organizations', key: 'orgs' });
          if (superUser && !isCustomer) nav.push({ href: '/app/leads', icon: 'mail', label: 'Leads', key: 'leads' });
        %>
        <% for (const item of nav) { const isActive = (typeof active !== 'undefined' && active === item.key); %>
          <a href="<%= item.href %>"
             class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition
                    <%= isActive ? 'bg-accent/15 text-white border border-accent/30' : 'text-slate-400 hover:text-slate-200 hover:bg-panel2 border border-transparent' %>">
            <i data-lucide="<%= item.icon %>" style="width:16px;height:16px;"></i>
            <span><%= item.label %></span>
          </a>
        <% } %>
      </nav>
      <div class="px-3 py-4 border-t border-line">
        <form method="post" action="/app/logout">
          <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-slate-400 hover:text-red-400 hover:bg-red-500/10 transition">
            <i data-lucide="log-out" style="width:16px;height:16px;"></i>
            <span>Sign out</span>
          </button>
        </form>
      </div>
    </aside>

    <!-- Main -->
    <div class="flex-1 min-w-0 flex flex-col">
      <header class="h-16 border-b border-line bg-panel/40 backdrop-blur flex items-center justify-between px-5 md:px-8">
        <div class="flex items-center gap-3">
          <span class="md:hidden text-sm font-semibold text-white">FORTRIX</span>
          <h1 class="text-base md:text-lg font-semibold text-white"><%= typeof title !== 'undefined' ? title : '' %></h1>
        </div>
        <div class="flex items-center gap-3">
          <% if (typeof isSuper !== 'undefined' && isSuper && typeof orgs !== 'undefined' && orgs.length > 0) { %>
            <form method="post" action="/app/org/switch" class="hidden sm:block">
              <select name="org_id" onchange="this.form.submit()"
                      class="bg-ink border border-line rounded-xl px-2.5 py-1.5 text-xs text-slate-300 focus:outline-none focus:border-accent/60">
                <% for (const o of orgs) { %>
                  <option value="<%= o.id %>" <%= (typeof currentOrg !== 'undefined' && currentOrg.id === o.id) ? 'selected' : '' %>><%= o.name %></option>
                <% } %>
              </select>
            </form>
          <% } else if (typeof currentOrg !== 'undefined') { %>
            <span class="hidden sm:inline text-xs text-slate-500"><%= currentOrg.name %></span>
          <% } %>
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <% if (typeof currentUser !== 'undefined') { %>
              <span class="hidden sm:inline"><%= currentUser.username %> · <span class="text-slate-600"><%= currentUser.role.replace('_', ' ') %></span></span>
              <div class="w-7 h-7 rounded-full bg-accent/20 border border-accent/40 flex items-center justify-center text-accent text-xs font-semibold"><%= currentUser.username.slice(0, 1).toUpperCase() %></div>
            <% } %>
          </div>
        </div>
      </header>
      <main class="flex-1 p-5 md:p-8 space-y-6">
        <% if (typeof flash !== 'undefined' && flash) { %>
          <div class="px-4 py-3 rounded-2xl text-sm <%= flash.type === 'error' ? 'bg-red-500/10 border border-red-500/30 text-red-400' : 'bg-emerald-500/10 border border-emerald-500/30 text-emerald-400' %>">
            <div class="flex items-center gap-2">
              <i data-lucide="<%= flash.type === 'error' ? 'alert-circle' : 'check-circle' %>" style="width:16px;height:16px;"></i>
              <span><%= flash.message %></span>
            </div>
            <% if (flash.creds) { %>
              <div class="mt-2 p-3 rounded-xl bg-ink border border-line font-mono text-xs text-slate-300">
                <div>Username: <span class="text-white"><%= flash.creds.username %></span></div>
                <div>Password: <span class="text-white"><%= flash.creds.password %></span></div>
                <div class="mt-1 text-slate-500 font-sans">⚠ Shown once — copy now and share via a secure channel.</div>
              </div>
            <% } %>
          </div>
        <% } %>
        <%- body %>
      </main>
    </div>
  </div>
<% } %>
<script>
  if (window.lucide) lucide.createIcons();
  // localize UTC timestamps
  document.querySelectorAll('[data-ts]').forEach(function (el) {
    var raw = el.getAttribute('data-ts');
    if (!raw) return;
    var d = new Date(raw.replace(' ', 'T') + 'Z');
    if (!isNaN(d.getTime())) el.textContent = d.toLocaleString();
  });
</script>
</body>
</html>
