<div class="bg-panel border border-line rounded-2xl p-5">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-white">Early access leads</h2>
    <span class="text-xs text-slate-500"><%= leads.length %> lead<%= leads.length === 1 ? '' : 's' %></span>
  </div>
  <% if (leads.length === 0) { %>
    <div class="text-sm text-slate-500 py-10 text-center">
      No leads yet.<br/>
      <span class="text-xs">Submissions from the landing page "Request Early Access" form will appear here.</span>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs uppercase tracking-wider text-slate-500 border-b border-line">
            <th class="py-2.5 pr-4 font-medium">Email</th>
            <th class="py-2.5 pr-4 font-medium">Name</th>
            <th class="py-2.5 pr-4 font-medium">Company</th>
            <th class="py-2.5 pr-4 font-medium">Message</th>
            <th class="py-2.5 pr-4 font-medium">Source</th>
            <th class="py-2.5 font-medium">Received</th>
          </tr>
        </thead>
        <tbody>
          <% for (const l of leads) { %>
            <tr class="border-b border-line/50 hover:bg-panel2/60">
              <td class="py-2.5 pr-4"><a class="text-accent hover:underline font-medium" href="mailto:<%= l.email %>"><%= l.email %></a></td>
              <td class="py-2.5 pr-4 text-slate-300"><%= l.name || '—' %></td>
              <td class="py-2.5 pr-4 text-slate-300"><%= l.company || '—' %></td>
              <td class="py-2.5 pr-4 text-slate-400 max-w-xs">
                <% const msg = l.message || ''; %>
                <span title="<%= msg %>"><%= msg ? (msg.length > 80 ? msg.slice(0, 80) + '…' : msg) : '—' %></span>
              </td>
              <td class="py-2.5 pr-4"><span class="px-2 py-0.5 rounded-lg text-[10px] font-medium bg-slate-500/15 text-slate-300 border border-slate-500/30"><%= l.source %></span></td>
              <td class="py-2.5 text-slate-500 text-xs" data-ts="<%= l.created_at %>"><%= l.created_at %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
